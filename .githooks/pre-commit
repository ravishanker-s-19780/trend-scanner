#!/bin/bash
# Pre-commit hook: Validate and format skill files
# Runs before each commit to ensure quality standards

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
SKILLS_DIR="$SCRIPT_DIR/skills"
VALIDATE_SCRIPT="$SKILLS_DIR/garment-features/scripts/validate_output.py"

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit hooks..."

# Check if skills directory exists
if [ ! -d "$SKILLS_DIR" ]; then
    echo "⚠️  Skills directory not found: $SKILLS_DIR"
    exit 0
fi

# Track if any validation failed
VALIDATION_FAILED=0

# Find all JSON files in skills/garment-features that are staged
STAGED_JSON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "skills/garment-features.*\.json" || true)

if [ -z "$STAGED_JSON_FILES" ]; then
    echo "✓ No skill JSON files to validate"
else
    echo "📋 Validating JSON files..."

    for json_file in $STAGED_JSON_FILES; do
        full_path="$SCRIPT_DIR/$json_file"

        if [ -f "$full_path" ]; then
            echo "  Checking: $json_file"

            # Auto-format JSON
            if command -v jq &> /dev/null; then
                # Use jq to format JSON prettily
                jq '.' "$full_path" > "$full_path.tmp" 2>/dev/null
                if [ $? -eq 0 ]; then
                    mv "$full_path.tmp" "$full_path"
                    git add "$full_path"
                    echo "    ✓ Formatted with jq"
                else
                    rm -f "$full_path.tmp"
                    echo -e "    ${RED}✗ Invalid JSON syntax${NC}"
                    VALIDATION_FAILED=1
                fi
            else
                # Fallback: just validate syntax
                python3 -m json.tool "$full_path" > /dev/null 2>&1
                if [ $? -eq 0 ]; then
                    echo "    ✓ Valid JSON"
                else
                    echo -e "    ${RED}✗ Invalid JSON syntax${NC}"
                    VALIDATION_FAILED=1
                fi
            fi

            # Run skill-specific validation if script exists
            if [ -f "$VALIDATE_SCRIPT" ]; then
                if python3 "$VALIDATE_SCRIPT" "$full_path" > /dev/null 2>&1; then
                    echo "    ✓ Skill validation passed"
                else
                    echo -e "    ${RED}✗ Skill validation failed${NC}"
                    python3 "$VALIDATE_SCRIPT" "$full_path"
                    VALIDATION_FAILED=1
                fi
            fi
        fi
    done
fi

# Check for uncommitted changes in SKILL.md (should be committed before changes)
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep "skills/.*\.md" || true)
if [ ! -z "$STAGED_MD" ]; then
    echo "📝 Markdown files modified: documentation updated"
fi

# Final result
echo ""
if [ $VALIDATION_FAILED -eq 0 ]; then
    echo -e "${GREEN}✓ All pre-commit checks passed${NC}"
    exit 0
else
    echo -e "${RED}✗ Pre-commit validation failed${NC}"
    echo ""
    echo "Fix the errors above and try committing again."
    echo "Or use: git commit --no-verify (not recommended)"
    exit 1
fi
