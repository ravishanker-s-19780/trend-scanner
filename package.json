{
  "name": "trend-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "One-shot nighty crawler — 8 platforms, 100 items each (~800 total). Output: evidence/original/<platform>.json.",
  "scripts": {
    "postinstall": "playwright install chromium",
    "scrape": "node skills/ecommerce-nighty-crawler/scripts/crawler.js",
    "scrape:amazon": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=amazon",
    "scrape:myntra": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=myntra",
    "scrape:flipkart": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=flipkart",
    "scrape:ajio": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=ajio",
    "scrape:meesho": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=meesho",
    "scrape:clovia": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=clovia",
    "scrape:tatacliq": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=tatacliq",
    "scrape:shyaway": "node skills/ecommerce-nighty-crawler/scripts/crawler.js --platforms=shyaway",
    "normalize": "node skills/evidence-cleanup/scripts/normalize.js",
    "analyze": "node skills/b2b-trend-scorer/scripts/analyze-trends.js",
    "analyze:top10": "node skills/b2b-trend-scorer/scripts/analyze-trends.js --top=10",
    "pipeline": "npm run normalize && npm run analyze"
  },
  "dependencies": {
    "playwright": "^1.47.0"
  }
}
